<%- include('partials/header') %>

<!-- HERO -->
<section class="hero" id="home">
  <div class="hero-content">
    <div class="hero-badge">
      <span class="dot"></span> Available for Projects
    </div>
    <h1>I Build <span>Digital Solutions</span> That Actually Work</h1>
    <p>Full-stack developer & automation engineer specializing in websites, web apps, AI integrations, and IoT systems. Affordable, fast, and built for your real-world needs.</p>
    <div class="hero-btns">
      <a href="#projects" class="btn-primary">View My Work ↓</a>
      <a href="#contact" class="btn-outline">Start a Project</a>
    </div>
    <div class="hero-stats">
      <div class="stat-item">
        <div class="stat-num">5+</div>
        <div class="stat-label">Projects Built</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">3</div>
        <div class="stat-label">Tech Domains</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">24h</div>
        <div class="stat-label">Response Time</div>
      </div>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section id="services">
  <div class="section-tag">What I Do</div>
  <h2 class="section-title">Core Services</h2>
  <p class="section-sub">Practical solutions for businesses, startups, and students — without the big-agency price tag.</p>
  <div class="services-grid">
    <div class="service-card">
      <div class="service-icon">🌐</div>
      <h3>Website Development</h3>
      <p>Business sites, portfolios, landing pages — fast-loading, mobile-ready, and professionally designed.</p>
      <span class="service-price">₹5,000 – ₹25,000</span>
    </div>
    <div class="service-card">
      <div class="service-icon">⚙️</div>
      <h3>Web Application Development</h3>
      <p>Custom dashboards, admin panels, and internal tools built with Node.js and MongoDB.</p>
      <span class="service-price">₹15,000 – ₹60,000</span>
    </div>
    <div class="service-card">
      <div class="service-icon">🤖</div>
      <h3>AI Integration</h3>
      <p>Add AI chatbots, smart assistants, and productivity automation to your platform.</p>
      <span class="service-price">₹10,000 – ₹50,000</span>
    </div>
    <div class="service-card">
      <div class="service-icon">🔁</div>
      <h3>Automation Solutions</h3>
      <p>Eliminate repetitive tasks with workflow automation and data processing pipelines.</p>
      <span class="service-price">₹10,000 – ₹50,000</span>
    </div>
    <div class="service-card">
      <div class="service-icon">🔌</div>
      <h3>IoT & Hardware Projects</h3>
      <p>ESP32-based systems, sensor integrations, and smart device prototypes.</p>
      <span class="service-price">₹8,000 – ₹40,000</span>
    </div>
    <div class="service-card">
      <div class="service-icon">🎓</div>
      <h3>Student Project Solutions</h3>
      <p>End-to-end support for academic projects — development, documentation, and guidance.</p>
      <span class="service-price">₹1,000 – ₹10,000</span>
    </div>
  </div>
</section>

<!-- PROJECTS -->
<section id="projects">
  <div class="section-tag">Portfolio</div>
  <h2 class="section-title">Projects Built</h2>
  <p class="section-sub">Real projects across software, robotics, and IoT systems.</p>
  <div class="projects-grid">
    <div class="project-card">
      <div class="project-img p-blue">🤖</div>
      <div class="project-body">
        <h3>Line Following Robot (LFR)</h3>
        <p>ESP32-powered autonomous robot with 8-sensor array for high-precision path tracking. Built for competitive robotics.</p>
        <div class="project-tags">
          <span class="tag">ESP32</span>
          <span class="tag">Embedded C</span>
          <span class="tag">Sensors</span>
          <span class="tag">Robotics</span>
        </div>
      </div>
    </div>
    <div class="project-card">
      <div class="project-img p-green">💸</div>
      <div class="project-body">
        <h3>Expense Tracker App</h3>
        <p>Full-stack web application to track income and expenses with categorization, filtering, and monthly reports.</p>
        <div class="project-tags">
          <span class="tag">Node.js</span>
          <span class="tag">MongoDB</span>
          <span class="tag">Express</span>
          <span class="tag">JavaScript</span>
        </div>
      </div>
    </div>
    <div class="project-card">
      <div class="project-img p-orange">🚗</div>
      <div class="project-body">
        <h3>UGV Prototype</h3>
        <p>Unmanned Ground Vehicle with custom drivetrain and propulsion system designed for field navigation tasks.</p>
        <div class="project-tags">
          <span class="tag">Embedded Systems</span>
          <span class="tag">Motor Control</span>
          <span class="tag">Fusion 360</span>
          <span class="tag">IoT</span>
        </div>
      </div>
    </div>
    <div class="project-card">
      <div class="project-img p-pink">🏥</div>
      <div class="project-body">
        <h3>IoT Dialysis Monitor</h3>
        <p>Biomedical device with real-time IoT monitoring and automated alerts for dialysis session safety tracking.</p>
        <div class="project-tags">
          <span class="tag">ESP32</span>
          <span class="tag">IoT</span>
          <span class="tag">Biomedical</span>
          <span class="tag">Dashboard</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PRICING -->
<section id="pricing">
  <div class="section-tag">Packages</div>
  <h2 class="section-title">Simple, Transparent Pricing</h2>
  <p class="section-sub">No hidden fees. Pay only for what you need. All projects include direct communication.</p>
  <div class="pricing-grid">
    <div class="pricing-card">
      <h3>Starter Website</h3>
      <div class="pricing-price">₹5,000</div>
      <div class="pricing-sub">Simple business or portfolio site</div>
      <ul class="pricing-features">
        <li>Up to 5 pages</li>
        <li>Mobile responsive</li>
        <li>Contact form</li>
        <li>Deployed & live</li>
        <li>1 revision round</li>
      </ul>
    </div>
    <div class="pricing-card featured">
      <span class="featured-badge">Most Popular</span>
      <h3>Business Website</h3>
      <div class="pricing-price">₹15,000</div>
      <div class="pricing-sub">Professional site with custom features</div>
      <ul class="pricing-features">
        <li>Up to 10 pages</li>
        <li>Custom design + branding</li>
        <li>CMS / Admin panel</li>
        <li>SEO optimization</li>
        <li>3 revision rounds</li>
      </ul>
    </div>
    <div class="pricing-card">
      <h3>Web Application</h3>
      <div class="pricing-price">₹25,000+</div>
      <div class="pricing-sub">Custom tools & dashboards</div>
      <ul class="pricing-features">
        <li>Full-stack development</li>
        <li>Database integration</li>
        <li>User authentication</li>
        <li>API development</li>
        <li>Deployment included</li>
      </ul>
    </div>
    <div class="pricing-card">
      <h3>Student Project</h3>
      <div class="pricing-price">₹2,000+</div>
      <div class="pricing-sub">Academic project support</div>
      <ul class="pricing-features">
        <li>Software development</li>
        <li>Hardware/IoT guidance</li>
        <li>Documentation & report</li>
        <li>Presentation support</li>
        <li>Fast turnaround</li>
      </ul>
    </div>
  </div>
</section>

<!-- CONTACT -->
<section id="contact">
  <div class="section-tag">Get In Touch</div>
  <h2 class="section-title">Let's Build Together</h2>
  <p class="section-sub">Have a project in mind? Tell me about it and I'll get back to you within 24 hours.</p>
  <form id="contactForm">
    <div class="form-row">
      <div class="form-group">
        <label>Your Name</label>
        <input type="text" name="name" placeholder="John Doe" required />
      </div>
      <div class="form-group">
        <label>Email Address</label>
        <input type="email" name="email" placeholder="you@example.com" required />
      </div>
    </div>
    <div class="form-group">
      <label>Service Required</label>
      <select name="service">
        <option>Website Development</option>
        <option>Web Application</option>
        <option>AI Integration</option>
        <option>Automation Solution</option>
        <option>IoT / Hardware Project</option>
        <option>Student Project</option>
        <option>Other / Not Sure</option>
      </select>
    </div>
    <div class="form-group">
      <label>Budget Range</label>
      <select name="budget">
        <option>Under ₹5,000</option>
        <option>₹5,000 – ₹15,000</option>
        <option>₹15,000 – ₹40,000</option>
        <option>₹40,000 – ₹1,00,000</option>
        <option>Above ₹1,00,000</option>
      </select>
    </div>
    <div class="form-group">
      <label>Project Description</label>
      <textarea name="message" placeholder="Tell me about your project — what you need, your timeline, and any specific requirements..."></textarea>
    </div>
    <button type="submit" class="btn-submit">Send Message →</button>
    <p id="formMsg"></p>
  </form>
</section>

<%- include('partials/footer') %>
